{
  "name": "growthamaster",
  "version": "1.0.0",
  "description": "GrowthMaster Solutions Consultancy website",
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/input.css -o ./static/css/output.css",
    "watch:css": "tailwindcss -i ./static/src/input.css -o ./static/css/output.css --watch",
    "build:css:prod": "tailwindcss -i ./static/src/input.css -o ./static/css/output.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
