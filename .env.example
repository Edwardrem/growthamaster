# Django core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Email (SMTP)
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=noreply@growthmaster.zw
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=GrowthMaster <noreply@growthmaster.zw>
ADMIN_EMAIL=admin@growthmaster.zw

BASE_URL=http://127.0.0.1:8000

# Seeded portal accounts (login at /accounts/login/)
# admin — superuser (Django admin + /manage/); staff — /manage/ portal only
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
STAFF_USERNAME=staff
STAFF_PASSWORD=your-staff-password
